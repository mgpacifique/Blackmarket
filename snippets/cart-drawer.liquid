<style>
  #CartDrawer .modal-content {
    transform: translateY(100%);
  }
</style>

<div id="CartDrawer" class="product-detail-modal fixed inset-0 isolate z-500 flex justify-center pointer-events-none hidden" data-handle="cart">
  <!-- Backdrop -->
  <div class="modal-bg-color -z-1 absolute inset-0 cursor-default appearance-none bg-white opacity-0" id="CartDrawer-Overlay"></div>
  
  <!-- Content Wrapper -->
  <div class="modal-content md:span-w-6 h-full w-full md:py-10">
    <div class="relative h-full w-full md:rounded-lg overflow-clip bg-grey text-black">
      
      <!-- Inside card: cart layout -->
      <div class="flex h-full w-full flex-col justify-between p-20 pb-20">
        
        <!-- Header -->
        <div class="flex items-center justify-between pb-16 border-b border-black/10 shrink-0">
          <h2 class="font-bold text-12 text-grey-60 uppercase tracking-wide">Panier</h2>
          <button class="custom-cart-close group overflow-clip rounded-xs" type="button" aria-label="Close cart">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="#D0D0D0" viewBox="0 0 24 24" role="presentation" class="w-24 stroke-grey-60/60 group-hover:stroke-grey-60"><path stroke-width="1.5" d="M17.331 12.75H6.668"></path></svg>
          </button>
        </div>

        <!-- Body / Items List -->
        <div class="custom-cart-body flex-1 overflow-y-auto my-20 scrollbar-hide pr-4" id="CartDrawer-Body">
          {%- if cart.item_count > 0 -%}
            <div class="custom-cart-items flex flex-col gap-16">
              {%- for item in cart.items -%}
                <div class="custom-cart-item flex gap-16 items-center" data-line-index="{{ forloop.index }}">
                  <div class="custom-cart-item-image h-69 w-69 shrink-0 overflow-clip rounded-xs bg-white border border-black/5">
                    <img src="{{ item.image | image_url: width: 150 }}" alt="{{ item.title | escape }}" class="h-full w-full object-contain">
                  </div>
                  <div class="custom-cart-item-details flex-1 flex flex-col justify-center min-w-0">
                    <div class="flex justify-between items-start">
                      <a href="{{ item.url }}" class="font-bold text-12 text-black uppercase truncate mr-8 hover:text-grey-60">{{ item.product.title }}</a>
                      <span class="font-bold text-12 text-black shrink-0">{{ item.final_line_price | money_without_trailing_zeros }}</span>
                    </div>
                    {%- unless item.product.has_only_default_variant -%}
                      <div class="text-10 text-grey-40 uppercase font-medium mt-4">{{ item.variant.title }}</div>
                    {%- endunless -%}
                    <div class="flex justify-between items-center mt-8">
                      <!-- Stepper -->
                      <div class="flex items-center rounded border border-black/10 bg-white" style="height:28px;">
                        <button type="button" class="cart-qty-minus px-10 text-12 font-bold text-grey-40 hover:text-black focus:outline-none" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | minus: 1 }}">-</button>
                        <input type="text" value="{{ item.quantity }}" class="w-24 text-center text-12 font-bold text-black bg-transparent border-none focus:outline-none pointer-events-none" readonly>
                        <button type="button" class="cart-qty-plus px-10 text-12 font-bold text-grey-40 hover:text-black focus:outline-none" data-line="{{ forloop.index }}" data-qty="{{ item.quantity | plus: 1 }}">+</button>
                      </div>
                      <button type="button" class="cart-remove-btn text-10 text-grey-40 font-bold hover:text-black focus:outline-none uppercase" data-line="{{ forloop.index }}">Retirer</button>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="custom-cart-empty h-full flex flex-col items-center justify-center py-60">
              <span class="font-bold text-12 text-grey-40 uppercase">Votre panier est vide</span>
            </div>
          {%- endif -%}
        </div>

        <!-- Footer / Checkout -->
        <div class="custom-cart-footer pt-16 border-t border-black/10 shrink-0">
          {%- if cart.item_count > 0 -%}
            <div class="flex justify-between items-center mb-16">
              <span class="font-bold text-12 text-grey-60 uppercase">Total</span>
              <span class="font-bold text-16 text-black" id="CartDrawer-Total">{{ cart.total_price | money_without_trailing_zeros }}</span>
            </div>
            <form action="{{ routes.cart_url }}" method="post" id="CartDrawer-Form">
              <button type="submit" name="checkout" class="w-full bg-black hover:bg-grey-60 text-white font-bold py-14 px-20 rounded-md text-12 uppercase tracking-wide transition-colors flex justify-center items-center">
                Commander
              </button>
            </form>
          {%- endif -%}
          <button type="button" class="custom-cart-close w-full text-center mt-12 text-10 text-grey-40 font-bold hover:text-black focus:outline-none uppercase">
            Continuer mes achats
          </button>
        </div>
        
      </div>
    </div>
  </div>
</div>