{% doc %}
  @prompt
    Product description page.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-description-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-product-description__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    font-weight: 700;
  }

  .ai-product-description__vendor-{{ ai_gen_id }} {
    font-size: {{ block.settings.vendor_size }}px;
    color: {{ block.settings.vendor_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-product-description__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-product-description__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-product-description__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size | times: 0.8 }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
  }

  .ai-product-description__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 4px 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: 12px;
    border-radius: {{ block.settings.badge_radius }}px;
    font-weight: 600;
  }

  .ai-product-description__content-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-product-description__content-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-product-description__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-product-description__meta-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: {{ block.settings.spacing }}px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-product-description__meta-item-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.meta_color }};
  }

  .ai-product-description__meta-label-{{ ai_gen_id }} {
    font-weight: 600;
    min-width: 80px;
  }

  .ai-product-description__meta-value-{{ ai_gen_id }} {
    color: {{ block.settings.meta_value_color }};
  }

  .ai-product-description__empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: {{ block.settings.description_color }};
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-product-description__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-product-description__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<product-description-{{ ai_gen_id }} class="ai-product-description-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product %}
    {% if block.settings.show_vendor and product.vendor != blank %}
      <div class="ai-product-description__vendor-{{ ai_gen_id }}">
        {{ product.vendor }}
      </div>
    {% endif %}

    {% if block.settings.show_title %}
      <h1 class="ai-product-description__title-{{ ai_gen_id }}">
        {{ product.title }}
      </h1>
    {% endif %}

    {% if block.settings.show_price %}
      <div class="ai-product-description__price-wrapper-{{ ai_gen_id }}">
        <div class="ai-product-description__price-{{ ai_gen_id }}">
          {{ product.selected_or_first_available_variant.price | money }}
        </div>

        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <div class="ai-product-description__compare-price-{{ ai_gen_id }}">
            {{ product.selected_or_first_available_variant.compare_at_price | money }}
          </div>

          {% if block.settings.show_sale_badge %}
            <span class="ai-product-description__badge-{{ ai_gen_id }}">
              {{ block.settings.sale_badge_text }}
            </span>
          {% endif %}
        {% endif %}

        {% if product.selected_or_first_available_variant.available == false and block.settings.show_sold_out_badge %}
          <span class="ai-product-description__badge-{{ ai_gen_id }}">
            {{ block.settings.sold_out_badge_text }}
          </span>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_description and product.description != blank %}
      <div class="ai-product-description__content-{{ ai_gen_id }}">
        {{ product.description }}
      </div>
    {% endif %}

    {% if block.settings.show_meta %}
      <div class="ai-product-description__meta-{{ ai_gen_id }}">
        {% if block.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
          <div class="ai-product-description__meta-item-{{ ai_gen_id }}">
            <span class="ai-product-description__meta-label-{{ ai_gen_id }}">SKU:</span>
            <span class="ai-product-description__meta-value-{{ ai_gen_id }}">
              {{ product.selected_or_first_available_variant.sku }}
            </span>
          </div>
        {% endif %}

        {% if block.settings.show_type and product.type != blank %}
          <div class="ai-product-description__meta-item-{{ ai_gen_id }}">
            <span class="ai-product-description__meta-label-{{ ai_gen_id }}">Type:</span>
            <span class="ai-product-description__meta-value-{{ ai_gen_id }}">
              {{ product.type }}
            </span>
          </div>
        {% endif %}

        {% if block.settings.show_availability %}
          <div class="ai-product-description__meta-item-{{ ai_gen_id }}">
            <span class="ai-product-description__meta-label-{{ ai_gen_id }}">Availability:</span>
            <span class="ai-product-description__meta-value-{{ ai_gen_id }}">
              {% if product.selected_or_first_available_variant.available %}
                In stock
              {% else %}
                Out of stock
              {% endif %}
            </span>
          </div>
        {% endif %}
      </div>
    {% endif %}
  {% else %}
    <div class="ai-product-description__empty-{{ ai_gen_id }}">
      Next, add this block to a product page template
    </div>
  {% endif %}
</product-description-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductDescription{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeVariantChange();
      }

      initializeVariantChange() {
        if (typeof window.Shopify !== 'undefined' && window.Shopify.theme) {
          document.addEventListener('variant:change', (event) => {
            if (event.detail && event.detail.variant) {
              this.updateVariantInfo(event.detail.variant);
            }
          });
        }
      }

      updateVariantInfo(variant) {
        const priceElement = this.querySelector('.ai-product-description__price-{{ ai_gen_id }}');
        const comparePriceElement = this.querySelector('.ai-product-description__compare-price-{{ ai_gen_id }}');
        const skuElement = this.querySelector('.ai-product-description__meta-item-{{ ai_gen_id }}:has(.ai-product-description__meta-label-{{ ai_gen_id }}:contains("SKU")) .ai-product-description__meta-value-{{ ai_gen_id }}');

        if (priceElement && variant.price) {
          priceElement.textContent = Shopify.formatMoney(variant.price, window.theme.moneyFormat || '{{amount}}');
        }

        if (comparePriceElement && variant.compare_at_price) {
          if (variant.compare_at_price > variant.price) {
            comparePriceElement.textContent = Shopify.formatMoney(variant.compare_at_price, window.theme.moneyFormat || '{{amount}}');
            comparePriceElement.style.display = 'block';
          } else {
            comparePriceElement.style.display = 'none';
          }
        }

        if (skuElement && variant.sku) {
          skuElement.textContent = variant.sku;
        }
      }
    }

    customElements.define('product-description-{{ ai_gen_id }}', ProductDescription{{ ai_gen_id }});
  })();
</script>

