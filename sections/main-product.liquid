      "default": "scheme-1",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        { "value": "large", "label": "Large" }
      ],
      "default": "large",
      "label": "Media size"
    },
    {
      "type": "checkbox",
      "id": "constrain_to_viewport",
      "label": "Constrain to viewport",
      "default": true
    },
    {
      "type": "select",
      "id": "media_fit",
      "options": [
        { "value": "contain", "label": "Contain" }
      ],
      "default": "contain",
      "label": "Media fit"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        { "value": "stacked", "label": "Stacked" }
      ],
      "default": "stacked",
      "label": "Gallery layout"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "options": [
        { "value": "hide", "label": "Hide" }
      ],
      "default": "hide",
      "label": "Mobile thumbnails"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        { "value": "left", "label": "Left" }
      ],
      "default": "left",
      "label": "Media position"
    },
    {
      "type": "select",
      "id": "image_zoom",
      "options": [
        { "value": "lightbox", "label": "Lightbox" }
      ],
      "default": "lightbox",
      "label": "Image zoom"
    },
    {
      "type": "checkbox",
      "id": "hide_variants",
      "label": "Hide variants",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Enable video looping",
      "default": false
