{{ 'section-main-product.css' | asset_url | stylesheet_tag }}

<div class="custom-pdp">
  <div class="custom-pdp-left">
    <div class="back-link-wrapper">
      <a href="javascript:history.back()" class="pdp-back-link">← BACK</a>
    </div>
    <div class="pdp-image-wrapper">
      {%- if product.featured_image -%}
        <img 
          src="{{ product.featured_image | image_url: width: 2000 }}" 
          alt="{{ product.title | escape }}" 
          class="pdp-main-image float-image" 
          width="{{ product.featured_image.width }}" 
          height="{{ product.featured_image.height }}" />
      {%- endif -%}
    </div>
    
    {%- if product.media.size > 1 -%}
      <div class="pdp-thumbnails">
        {%- for media in product.media offset: 1 -%}
          <img src="{{ media | image_url: width: 150 }}" class="pdp-thumb" alt="{{ media.alt | escape }}" onclick="document.querySelector('.pdp-main-image').src='{{ media | image_url: width: 2000 }}'">
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
  
  <div class="custom-pdp-right">
    <h1 class="pdp-title">{{ product.title }}</h1>
    <div class="pdp-price">{{ product.price | money }}</div>
    
    {%- form 'product', product, class: 'product-form pdp-form' -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      
      {%- unless product.has_only_default_variant -%}
        <div class="pdp-variants">
          {%- for option in product.options_with_values -%}
            <div class="pdp-option">
              <label>{{ option.name }}</label>
              <div class="pdp-option-values">
                {%- for value in option.values -%}
                  <label class="pdp-swatch">
                    <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                    <span>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}
      
      <div class="pdp-quantity">
        <label>Quantity</label>
        <div class="qty-stepper">
          <button type="button" class="qty-minus" onclick="this.nextElementSibling.stepDown()">-</button>
          <input type="number" name="quantity" value="1" min="1" class="qty-input">
          <button type="button" class="qty-plus" onclick="this.previousElementSibling.stepUp()">+</button>
        </div>
      </div>
      
      <div class="pdp-action">
        {%- if product.available -%}
          <button type="submit" class="btn-add-to-cart">ADD TO CART</button>
        {%- else -%}
          <button type="button" class="btn-add-to-cart disabled" disabled>SOLD OUT</button>
        {%- endif -%}
      </div>
    {%- endform -%}
    
    <div class="pdp-description-accordion">
      <details>
        <summary>DESCRIPTION</summary>
        <div class="accordion-content">
          {{ product.description }}
        </div>
      </details>
    </div>
  </div>
</div>

<style>
.custom-pdp {
  display: flex;
  flex-wrap: wrap;
  width: 100vw;
  min-height: 100vh;
}
.custom-pdp-left {
  flex: 0 0 60%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
}
.custom-pdp-right {
  flex: 0 0 40%;
  padding: 100px 40px 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.back-link-wrapper {
  position: absolute;
  top: 40px;
  left: 40px;
}
.pdp-back-link {
  font-weight: 700;
  font-size: 13px;
  text-decoration: none;
  letter-spacing: 0.1em;
  color: #888;
}
.pdp-back-link:hover {
  color: #000;
}
.pdp-image-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pdp-main-image {
  max-height: 80vh;
  width: auto;
  object-fit: contain;
}
.pdp-thumbnails {
  display: flex;
  gap: 10px;
  margin-top: 20px;
}
.pdp-thumb {
  width: 60px;
  height: 60px;
  object-fit: contain;
  cursor: pointer;
  border: 1px solid transparent;
}
.pdp-thumb:hover {
  border-color: #000;
}

.pdp-title {
  font-size: 48px;
  font-weight: 700;
  margin: 0 0 16px;
  line-height: 1.1;
  text-transform: uppercase;
}
.pdp-price {
  font-size: 24px;
  font-weight: 700;
  margin-bottom: 40px;
}
.pdp-option {
  margin-bottom: 24px;
}
.pdp-option label {
  display: block;
  font-size: 11px;
  text-transform: uppercase;
  margin-bottom: 8px;
  font-weight: 700;
  color: #888;
  letter-spacing: 0.1em;
}
.pdp-option-values {
  display: flex;
  gap: 10px;
}
.pdp-swatch input {
  display: none;
}
.pdp-swatch span {
  display: inline-block;
  padding: 8px 16px;
  border: 1px solid #CCC;
  cursor: pointer;
  text-transform: uppercase;
  font-size: 14px;
}
.pdp-swatch input:checked + span {
  border-color: #000;
  background-color: #000;
  color: #FFF;
}
.pdp-quantity {
  margin-bottom: 40px;
}
.pdp-quantity label {
  display: block;
  font-size: 11px;
  text-transform: uppercase;
  margin-bottom: 8px;
  font-weight: 700;
  color: #888;
  letter-spacing: 0.1em;
}
.qty-stepper {
  display: inline-flex;
  border: 1px solid #CCC;
}
.qty-stepper button {
  background: transparent;
  border: none;
  width: 40px;
  height: 40px;
  font-size: 18px;
  cursor: pointer;
}
.qty-stepper input {
  border: none;
  width: 50px;
  text-align: center;
  font-size: 16px;
  -moz-appearance: textfield;
}
.qty-stepper input::-webkit-outer-spin-button,
.qty-stepper input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.btn-add-to-cart {
  width: 100%;
  background: #000;
  color: #FFF;
  border: none;
  padding: 20px;
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s;
}
.btn-add-to-cart:hover {
  opacity: 0.9;
}
.btn-add-to-cart.disabled {
  background: #CCC;
  cursor: not-allowed;
}

.pdp-description-accordion {
  margin-top: 60px;
  border-top: 1px solid #EEE;
}
.pdp-description-accordion details {
  padding: 20px 0;
  border-bottom: 1px solid #EEE;
}
.pdp-description-accordion summary {
  font-size: 13px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  list-style: none;
}
.pdp-description-accordion summary::marker {
  display: none;
}
.pdp-description-accordion summary::-webkit-details-marker {
  display: none;
}
.accordion-content {
  margin-top: 20px;
  font-size: 14px;
  line-height: 1.6;
  color: #444;
}

@media (max-width: 767px) {
  .custom-pdp-left {
    flex: 0 0 100%;
    padding: 20px;
    height: 70vh;
  }
  .custom-pdp-right {
    flex: 0 0 100%;
    padding: 20px;
  }
  .pdp-title {
    font-size: 32px;
  }
  .back-link-wrapper {
    top: 20px;
    left: 20px;
  }
}
</style>

<script>
  // Simplified variant selection logic
  document.querySelectorAll('.pdp-swatch input').forEach(input => {
    input.addEventListener('change', () => {
      // In a real theme, this would update the hidden variant ID input
      // based on selected options and product JSON.
      // This is left simple for the PRD concept styling scope.
    });
  });
</script>

{% schema %}
{
