{{ 'section-main-product.css' | asset_url | stylesheet_tag }}


<div class="simple-product-page">
  <div class="am-background"></div>

  <div class="simple-container">
    <!-- Left Column: Images -->
    <div class="simple-left-col">
      <div class="simple-main-image-wrapper">
        {%- if product.featured_image -%}
          <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" class="simple-main-image" id="simple-main-image" loading="eager">
        {%- endif -%}
      </div>
      
      {%- if product.media.size > 1 -%}
        <div class="simple-thumbnails">
          {%- for media in product.media -%}
            <button type="button" class="simple-thumb-btn {% if forloop.first %}is-active{% endif %}" data-image="{{ media | image_url: width: 1200 }}">
              <img src="{{ media | image_url: width: 150 }}" alt="{{ media.alt | escape }}">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Right Column: Info -->
    <div class="simple-right-col">
      <h1 class="simple-title">{{ product.title }}</h1>
      <p class="simple-price">{{ product.price | money }}</p>

      {%- form 'product', product, class: 'simple-product-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        
        {%- unless product.has_only_default_variant -%}
          <div class="simple-variants">
            {%- for option in product.options_with_values -%}
              <div class="simple-option">
                <label class="simple-option-label">{{ option.name }}</label>
                <div class="simple-option-values">
                  {%- for value in option.values -%}
                    <label class="simple-swatch">
                      <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %}>
                      <span class="simple-swatch-box">{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <button type="submit" class="simple-add-to-cart {% unless product.available %}disabled{% endunless %}" {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
        </button>
      {%- endform -%}

      <div class="simple-description">
        {{ product.description }}
      </div>
    </div>
  </div>
</div>

<style>
/* Simplified Product Page Layout */
.simple-product-page {
  position: relative;
  min-height: 100vh;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 60px 20px;
}

/* Kept background for color */
.am-background {
  position: fixed;
  inset: 0;
  z-index: -1;
  background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 1) 0%, rgba(240, 240, 240, 1) 40%, rgba(200, 200, 200, 1) 70%, rgba(20, 20, 20, 0.9) 100%);
}

.simple-container {
  display: flex;
  flex-direction: row;
  width: 100%;
  max-width: 1200px;
  gap: 60px;
}

/* Left Column */
.simple-left-col {
  flex: 1.2;
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.simple-main-image-wrapper {
  width: 100%;
  aspect-ratio: 1 / 1;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.simple-main-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.simple-thumbnails {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
}

.simple-thumb-btn {
  width: 80px;
  height: 80px;
  border: 1px solid rgba(0, 0, 0, 0.2);
  background: transparent;
  padding: 5px;
  cursor: pointer;
  transition: border-color 0.2s ease;
}
.simple-thumb-btn img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.simple-thumb-btn.is-active, .simple-thumb-btn:hover {
  border-color: #000;
}

/* Right Column */
.simple-right-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-top: 20px;
}

.simple-title {
  font-family: monospace, sans-serif;
  font-size: 28px;
  font-weight: bold;
  text-transform: uppercase;
  margin: 0 0 20px;
  line-height: 1.2;
}

.simple-price {
  font-family: monospace, sans-serif;
  font-size: 20px;
  font-weight: bold;
  margin: 0 0 40px;
}

/* Form Styles */
.simple-product-form {
  display: flex;
  flex-direction: column;
  gap: 30px;
  margin-bottom: 40px;
}

.simple-variants {
  display: flex;
  flex-direction: column;
  gap: 25px;
}

.simple-option {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.simple-option-label {
  font-family: monospace, sans-serif;
  font-size: 14px;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 1px;
}

.simple-option-values {
  display: flex;
  flex-wrap: wrap;
  gap: 0; /* Boxy layout with touching borders or slight gap */
}

.simple-swatch input {
  display: none;
}

.simple-swatch-box {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 60px;
  height: 50px;
  padding: 0 15px;
  border: 1px solid rgba(0, 0, 0, 0.2);
  font-family: monospace, sans-serif;
  font-size: 14px;
  font-weight: bold;
  text-transform: uppercase;
  cursor: pointer;
  background: transparent;
  margin-right: -1px; /* Overlap borders */
  margin-bottom: 10px;
}

.simple-swatch input:checked + .simple-swatch-box {
  border-color: #000;
  border-width: 1px;
  position: relative;
  z-index: 1;
  /* Add an "X" or just solid border to match active state, but color is same */
  background: rgba(0,0,0,0.05);
}

.simple-add-to-cart {
  background: transparent;
  color: #000;
  border: 1px solid rgba(0,0,0,0.2);
  padding: 15px 20px;
  font-family: monospace, sans-serif;
  font-size: 16px;
  font-weight: bold;
  text-transform: uppercase;
  cursor: pointer;
  width: max-content;
  min-width: 200px;
  text-align: center;
  transition: border-color 0.2s ease, background 0.2s ease;
}
.simple-add-to-cart:hover {
  border-color: #000;
  background: rgba(0,0,0,0.05);
}
.simple-add-to-cart.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.simple-description {
  font-family: monospace, sans-serif;
  font-size: 14px;
  line-height: 1.8;
  padding-top: 30px;
  border-top: 1px solid rgba(0, 0, 0, 0.1);
}

.simple-description ul {
  padding-left: 20px;
  margin: 10px 0;
}

.simple-description li {
  margin-bottom: 8px;
}

/* Mobile Responsive */
@media (max-width: 768px) {
  .simple-container {
    flex-direction: column;
    gap: 40px;
  }
  
  .simple-main-image-wrapper {
    aspect-ratio: auto;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Thumbnail Switcher
  const mainImage = document.getElementById('simple-main-image');
  const thumbs = document.querySelectorAll('.simple-thumb-btn');
  
  thumbs.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const newSrc = btn.getAttribute('data-image');
      if (mainImage && newSrc) {
        mainImage.src = newSrc;
        thumbs.forEach(t => t.classList.remove('is-active'));
        btn.classList.add('is-active');
      }
    });
  });
});
</script>

{% schema %}
{
  "name": "Main Product (Simple)",
  "settings": []
}
{% endschema %}
