<!-- Reduced Header: Logo + Context Label -->
<header class="custom-header">
  <div class="custom-header-logo">
    <a href="{{ routes.root_url }}">
      {%- if settings.logo != blank -%}
        <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}">
      {%- else -%}
        <span class="h2" style="font-weight: 700; color: #000;">{{ shop.name }}</span>
      {%- endif -%}
    </a>
  </div>
  
  <div class="custom-header-label">
    {%- if product -%}
      {{ product.metafields.antigravity.carousel_label.value | default: product.title }}
    {%- elsif collection -%}
      {{ collection.title }}
    {%- else -%}
      SHOP
    {%- endif -%}
  </div>
</header>

<style>
.custom-header {
  position: fixed;
  top: 0;
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 24px;
  z-index: 100;
  pointer-events: none;
}
.custom-header-logo {
  pointer-events: auto;
}
.custom-header-label {
  font-weight: 700;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #000;
  pointer-events: auto;
}
</style>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}