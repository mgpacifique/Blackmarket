<header class="fixed top-0 left-0 z-100 w-full p-10">
  <div class="header-wrapper flex h-44 min-h-[44px] items-center justify-between rounded-lg px-10 font-bold text-12 text-grey-40 uppercase md:px-20">
    <a class="group relative items-center appearance-none cursor-pointer overflow-clip disabled:pointer-events-none pointer-events-auto focus-visible:outline-2 outline-black outline-offset-4 inline-block h-30" href="{{ routes.root_url }}">
      <picture class="[&>img]:h-full [&>img]:w-auto">
        {% if section.settings.logo != blank %}
          <img class="block w-full object-cover" alt="{{ section.settings.logo.alt | default: shop.name | escape }}" src="{{ section.settings.logo | image_url: height: 60 }}" loading="lazy" decoding="async" height="30"/>
        {% else %}
          <span style="color: black;">{{ shop.name }}</span>
        {% endif %}
      </picture>
    </a>
    <div class="header-title flex items-center gap-16">
      <span id="product-display-title" class="font-bold text-12 uppercase tracking-wide text-black transition-opacity duration-300"></span>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('header');
    if (!header) return;

    let isMinimized = false;

    const updateHeaderState = () => {
      const hasHash = window.location.hash && window.location.hash.length > 1;
      const isCartOpen = document.body.classList.contains('cart-drawer-open');
      const shouldMinimize = hasHash || isCartOpen;

      if (shouldMinimize !== isMinimized) {
        isMinimized = shouldMinimize;
        gsap.to(header, {
          y: isMinimized ? '-100%' : '0%',
          duration: 0.8,
          ease: 'expo.inOut',
          overwrite: 'auto'
        });
      }
    };

    // Listen for hash transitions
    window.addEventListener('hashchange', updateHeaderState);
    
    // Listen for custom coverflow detail states
    window.addEventListener('coverflowDragStart', () => {
      // Re-enable header on coverflow interactions
      gsap.to(header, { y: '0%', duration: 0.8, ease: 'expo.inOut', overwrite: 'auto' });
    });

    // Observe body class changes for cart open
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'class') {
          updateHeaderState();
        }
      });
    });
    observer.observe(document.body, { attributes: true });

    // Initial state check
    updateHeaderState();
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ]
}
{% endschema %}