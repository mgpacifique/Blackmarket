{{ 'carousel.css' | asset_url | stylesheet_tag }}
<script src="{{ 'carousel.js' | asset_url }}" defer="defer"></script>

<div class="homepage-carousel-container" data-section-id="{{ section.id }}" data-collection="{{ section.settings.collection }}">
  <div class="carousel-track">
    {%- assign mock_images = "6756d28091cff91afd065e70163ee80c36549d8e-4096x4096.jpg,ae76f52285c8a241fa68044bbd3230c1e5f0912e-4096x4096.jpg,b293dad484f050100f9917b7d283dc63e1e400a9-1000x1000.jpg,c77f09a021af7a75a05d34e2d0f4a8964c719484-4096x4096.jpg,cb92d6edd9da527dd112a83c1aaf8445074c4476-1000x1000.jpg,df30d4a5bae9306d9d1400f5e1823b2d4fe75390-4096x4096.jpg" | split: "," -%}

    {%- for img in mock_images -%}
      <div class="carousel-slide {% if forloop.first %}is-active{% endif %}" data-product-handle="mock-{{ forloop.index }}" data-product-id="mock-{{ forloop.index }}" {% unless forloop.first %}aria-hidden="true"{% endunless %}>
        <div class="product-card-float" data-url="#" data-label="Mock Product {{ forloop.index }}">
          <a href="#" class="product-card-float-link" aria-label="View product {{ forloop.index }}">
            <div class="product-card-image-wrapper">
              <img src="{{ img | asset_url }}" alt="Mock Image {{ forloop.index }}" class="float-image" />
            </div>
          </a>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <div class="carousel-ui-overlay">
    <div class="carousel-logo">
      <a href="{{ routes.root_url }}">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="{{ settings.logo.width }}" height="{{ settings.logo.height }}">
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>
    
    <div class="carousel-active-label" id="ActiveProductLabel">
       <!-- Populated by JS -->
    </div>

    <!-- Navigation Wheel Component -->
    <div class="nav-wheel-wrapper">
      {% render 'nav-wheel' %}
    </div>
  </div>

  <!-- Menu Overlay -->
  <div class="menu-overlay" id="MenuOverlay" role="dialog" aria-modal="true" aria-label="Collections Menu" hidden>
    <div class="menu-overlay-inner">
      <ul class="collection-list">
        {%- for collection in collections -%}
          <li>
            <a href="#" data-collection-handle="{{ collection.handle }}" class="menu-collection-link">
              {{ collection.title }}
            </a>
          </li>
        {%- endfor -%}
      </ul>
      <button class="menu-close-btn" aria-label="Close menu">X</button>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Carousel Homepage",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured Collection (Default)"
    }
  ],
  "presets": [
    {
      "name": "Carousel Homepage",
      "category": "Custom"
    }
  ]
}
{% endschema %}