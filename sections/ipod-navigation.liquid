<style>
  /* Pixel-perfect Custom iPod Click Wheel Style matching reference image */
  .ipod-nav {
    width: 180px;
    height: 180px;
    background-color: transparent; /* Transparent container */
    border-radius: 50%;
    position: relative;
    overflow: visible;
  }
  
  /* Solid dark grey background on .ipod-menu-back with z-index: 1 */
  .ipod-menu-back {
    display: block; 
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 180px;
    height: 180px;
    background-image: linear-gradient(to bottom, #252525, #181818);
    border-radius: 9999px; /* Morphable pill */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  /* iPod arrows container */
  .ipod-arrows {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 16px; /* Inset arrows from edges */
    pointer-events: none;
  }

  .ipod-arrows button {
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
    transition: transform 0.1s;
    overflow: hidden;
  }
  
  .ipod-left-arrow, .ipod-right-arrow {
    position: relative;
    width: 30px;
    height: 30px;
  }

  .ipod-left-arrow svg, .ipod-right-arrow svg {
    width: 30px !important;
    height: 30px !important;
    display: block !important;
    position: absolute;
    top: 0;
    fill: #858585 !important;
    transition: fill 0.2s;
  }

  .ipod-left-arrow svg:first-child {
    left: 0;
  }

  .ipod-left-arrow svg:last-child {
    left: 200%;
  }

  .ipod-right-arrow svg:first-child {
    left: 0;
  }

  .ipod-right-arrow svg:last-child {
    left: -200%;
  }

  .ipod-left-arrow svg path, .ipod-right-arrow svg path {
    fill: inherit !important;
  }

  .ipod-arrows button:hover svg, .ipod-arrows button:hover svg path {
    fill: #ffffff !important;
  }

  .ipod-arrows button:active {
    transform: scale(0.9);
  }

  /* iPod top Menu button style */
  .ipod-menu-btn {
    position: absolute;
    top: 14px; /* Positioned near top edge */
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    z-index: 4;
    pointer-events: none;
  }

  .ipod-menu-btn button {
    background: none;
    border: none;
    color: #e5e5e5; /* Off-white uppercase text */
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    padding: 6px 12px;
    margin: 0;
    pointer-events: auto;
    transition: color 0.2s, transform 0.1s;
    overflow: hidden;
    position: relative;
    height: 24px;
    display: inline-block;
  }

  .ipod-menu-btn button:hover {
    color: #ffffff;
  }

  .ipod-menu-btn button:active {
    transform: scale(0.95);
  }

  /* Center Click Button */
  .ipod-menu-front {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 68px; /* Proportional center button size */
    height: 68px;
    background-color: #2b2b2b; /* Lighter solid grey button */
    border-radius: 50%;
    border: 1px solid #141414; /* Thin border separator */
    box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.05), 0 2px 4px rgba(0, 0, 0, 0.3);
    z-index: 3;
    transition: background-color 0.2s, transform 0.1s;
  }

  .ipod-center-btn {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: none;
    border: none;
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
  }

  .ipod-menu-front:hover {
    background-color: #333333;
  }

  .ipod-menu-front:active {
    background-color: #222222;
    transform: translate(-50%, -50%) scale(0.96);
  }
  
  /* Draggable overlay absolute fill */
  .ipod-wheel-draggable {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2; 
    border-radius: 50%;
  }

  /* Menu wrapper layout (placed exactly 52px above the wheel, centered) */
  .ipod-menu-wrapper {
    position: absolute;
    top: -72px; /* Fixed pixel positioning above the wheel */
    left: 50%;
    transform: translateX(-50%);
    z-index: 0; /* Under the wheel background (z-1) when collapsed */
    width: auto;
    height: auto;
    overflow: visible;
  }

  .ipod-menu-wrapper.is-active {
    z-index: 3; /* Above wheel background (z-1) but below buttons (z-4) */
  }

  .ipod-menu-wrapper nav {
    position: relative;
    top: 0;
    left: 0;
    transform: none;
    display: block;
    margin: 0;
    padding: 0;
    width: auto;
    height: auto;
  }

  /* iPod sliding menu container (transitions width and position) */
  .ipod-menu {
    width: 48px; /* Fully hidden behind the 180px wheel when collapsed */
    height: 44px;
    overflow: hidden;
    border-radius: 8px;
    background-color: #212121; /* Solid dark grey navbar background */
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 0 16px;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), width 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .ipod-menu.is-active {
    width: 330px; /* Smoothly expands to fit all links when active */
  }
</style>

<div id="ipod-nav-container" class="pointer-events-none fixed bottom-0 left-0 z-100 flex w-full justify-center">
  <div class="ipod-nav relative mb-24 aspect-square w-180 select-none rounded-full pointer-events-auto">
    <div class="ipod-menu-wrapper">
      <nav>
        <div class="ipod-menu" style="transform: translateY(80px);">
          
          {% if section.blocks.size > 0 %}
            {% for block in section.blocks %}
              {% assign is_active = false %}
              {% if block.settings.url == request.path or request.path == '/' and block.settings.url == '/collections/all' %}
                {% assign is_active = true %}
              {% endif %}
              <a aria-label="{{ block.settings.title }}" class="group relative flex items-center appearance-none cursor-pointer disabled:pointer-events-none pointer-events-auto focus-visible:outline-2 outline-black outline-offset-4 rounded-sm px-10 py-7 font-bold text-10 uppercase leading-none transition-colors delay-100 duration-300 {% if is_active %}bg-white text-black{% else %}bg-transparent text-white hover:bg-grey-50{% endif %}" href="{{ block.settings.url }}">{{ block.settings.title }}</a>
            {% endfor %}
          {% else %}
            <!-- Default Static Fallback Links (aligned with damso.com) -->
            <a aria-label="Shop" class="group relative flex items-center appearance-none cursor-pointer disabled:pointer-events-none pointer-events-auto focus-visible:outline-2 outline-black outline-offset-4 rounded-sm px-10 py-7 font-bold text-10 uppercase leading-none transition-colors delay-100 duration-300 {% if request.path == '/' or request.path == '/collections/all' %}bg-white text-black{% else %}bg-transparent text-white hover:bg-grey-50{% endif %}" href="/">Shop</a>
            <a aria-label="World" class="group relative flex items-center appearance-none cursor-pointer disabled:pointer-events-none pointer-events-auto focus-visible:outline-2 outline-black outline-offset-4 rounded-sm px-10 py-7 font-bold text-10 uppercase leading-none transition-colors delay-100 duration-300 {% if request.path == '/world' or request.path == '/pages/world' %}bg-white text-black{% else %}bg-transparent text-white hover:bg-grey-50{% endif %}" href="/world">World</a>
            <a aria-label="Tournée" class="group relative flex items-center appearance-none cursor-pointer disabled:pointer-events-none pointer-events-auto focus-visible:outline-2 outline-black outline-offset-4 rounded-sm px-10 py-7 font-bold text-10 uppercase leading-none transition-colors delay-100 duration-300 {% if request.path == '/tournee' or request.path == '/pages/tournee' %}bg-white text-black{% else %}bg-transparent text-white hover:bg-grey-50{% endif %}" href="/tournee">Tournée</a>
          {% endif %}

          <button class="ipod-cart-toggle-btn group relative flex items-center appearance-none cursor-pointer overflow-clip disabled:pointer-events-none pointer-events-auto focus-visible:outline-2 outline-black outline-offset-4 py-6 pr-8">
            <div class="relative flex h-30 w-32 items-end">
              <svg xmlns="http://www.w3.org/2000/svg" fill="#EDEDED" viewBox="0 0 24 24" role="presentation" class="w-24"><path d="M9.862 18.692a1.31 1.31 0 0 1-.809 1.209 1.31 1.31 0 0 1-1.428-.284 1.307 1.307 0 0 1 .927-2.232 1.31 1.31 0 0 1 1.31 1.307m7.207-1.307a1.31 1.31 0 0 0-1.21.807 1.305 1.305 0 0 0 .954 1.783 1.31 1.31 0 0 0 1.345-.556 1.306 1.306 0 0 0-1.09-2.034m3.907-10.287-2.1 7.542a1.966 1.966 0 0 1-1.889 1.437H8.892a1.97 1.97 0 0 1-1.896-1.437L4.123 4.308H2.655A.656.656 0 0 1 2 3.654.653.653 0 0 1 2.655 3h1.966a.656.656 0 0 1 .631.479l.776 2.79h14.317a.656.656 0 0 1 .631.829m-1.494.479H6.392l1.869 6.713a.654.654 0 0 0 .631.48h8.095a.655.655 0 0 0 .631-.48z"></path><path d="M5.672 6.886C6.4 9.5 7.855 14.819 7.855 15.168h10.046l2.621-8.282z"></path></svg>
              <div class="absolute top-0 right-0 flex h-18 w-18 items-center justify-center rounded-full bg-grey-40 font-medium text-10 leading-none text-white">
                <span class="">{{ cart.item_count }}</span>
              </div>
            </div>
          </button>
        </div>
      </nav>
    </div>
    
    <div class="ipod-menu-back"></div>
    <div class="ipod-wheel-draggable"></div>
    
    <div class="ipod-center absolute inset-1/2 z-1 transition-opacity" style="opacity: 0; pointer-events: none;">
      <div class="ipod-cursor -translate-1/2 absolute top-0 left-0 mt-58 aspect-square w-50 rounded-full" style="pointer-events: none;">
        <img alt="finger cursor" loading="lazy" width="55" height="55" decoding="async" class="opacity-50" src="{{ 'doigt.png' | asset_url }}" style="pointer-events: none;"/>
      </div>
    </div>
    
    <div class="ipod-arrows">
      <button class="ipod-left" type="button" aria-label="Previous">
        <div class="ipod-left-arrow relative h-30 w-30">
          <svg xmlns="http://www.w3.org/2000/svg" fill="#D0D0D0" viewBox="0 0 25 25" style="transform: rotate(180deg);"><path d="m21.428 12.281-7.313 4.14v-8.28zM13.25 12.281l-7.312 4.14v-8.28z"></path></svg>
          <svg xmlns="http://www.w3.org/2000/svg" fill="#D0D0D0" viewBox="0 0 25 25" class="absolute top-0 left-[200%]" style="transform: rotate(180deg);"><path d="m21.428 12.281-7.313 4.14v-8.28zM13.25 12.281l-7.312 4.14v-8.28z"></path></svg>
        </div>
      </button>
      <button class="ipod-right-btn" type="button" aria-label="Next">
        <div class="ipod-right-arrow relative h-30 w-30">
          <svg xmlns="http://www.w3.org/2000/svg" fill="#D0D0D0" viewBox="0 0 25 25"><path d="m21.428 12.281-7.313 4.14v-8.28zM13.25 12.281l-7.312 4.14v-8.28z"></path></svg>
          <svg xmlns="http://www.w3.org/2000/svg" fill="#D0D0D0" viewBox="0 0 25 25" class="absolute top-0 -left-[200%]"><path d="m21.428 12.281-7.313 4.14v-8.28zM13.25 12.281l-7.312 4.14v-8.28z"></path></svg>
        </div>
      </button>
    </div>
    
    <div class="ipod-menu-btn">
      <button type="button">
        <div class="ipod-menu-label px-12">
          <div class="relative"><span>menu</span></div>
        </div>
        <div class="ipod-menu-close group absolute inset-x-8 inset-y-0 mt-[3rem] flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="#C6C6C6" viewBox="0 0 25 25" class="w-26 rotate-90 group-hover:fill-white"><path d="m8.172 18.488-1.685-1.685 4.331-4.33-4.33-4.301 1.684-1.684 4.33 4.33 4.301-4.33 1.685 1.684-4.331 4.3 4.33 4.331-1.684 1.685-4.3-4.331z"></path></svg>
        </div>
      </button>
    </div>
    
    <div class="ipod-menu-front">
      <div class="absolute inset-0 z-4 flex items-center justify-center overflow-clip rounded-full">
        <button class="ipod-center-close-btn group relative flex items-center justify-center rounded-full p-16 outline-none" type="button" aria-label="Close modal">
          <div class="relative h-25 w-25">
            <svg xmlns="http://www.w3.org/2000/svg" fill="#C6C6C6" viewBox="0 0 25 25" class="ipod-center-close -translate-y-[200%] invisible w-full fill-grey-20 group-hover:fill-white" style="position: absolute; top:0; left:0;"><path d="m8.172 18.488-1.685-1.685 4.331-4.33-4.33-4.301 1.684-1.684 4.33 4.33 4.301-4.33 1.685 1.684-4.331 4.3 4.33 4.331-1.684 1.685-4.3-4.331z"></path></svg>
          </div>
        </button>
      </div>
      <button class="ipod-center-btn" type="button" aria-label="Select"></button>
    </div>
  </div>
</div>

<script src="{{ 'ipod-wheel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "iPod Navigation",
  "blocks": [
    {
      "type": "link",
      "name": "Navigation Link",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Link Title",
          "default": "Shop"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "iPod Navigation",
      "blocks": [
        {
          "type": "link",
          "settings": {
            "title": "Shop",
            "url": "/"
          }
        },
        {
          "type": "link",
          "settings": {
            "title": "World",
            "url": "/"
          }
        },
        {
          "type": "link",
          "settings": {
            "title": "Tournée",
            "url": "/"
          }
        }
      ]
    }
  ]
}
{% endschema %}
